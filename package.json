{
  "name": "scalyn-task-time-tracker-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Scalyn Task Time Tracker backend built with NestJS, Prisma, MySQL, and JWT auth.",
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run build:timer && npm run build:tasks && npm run build:reports && npm run build:team && tsc -p tsconfig.build.json",
    "build:timer": "vite build --config frontend/timer/vite.config.ts",
    "build:tasks": "vite build --config frontend/tasks/vite.config.ts",
    "build:reports": "vite build --config frontend/reports/vite.config.ts",
    "build:team": "vite build --config frontend/team/vite.config.ts",
    "dev:timer": "vite --config frontend/timer/vite.config.ts",
    "dev:tasks": "vite --config frontend/tasks/vite.config.ts",
    "dev:reports": "vite --config frontend/reports/vite.config.ts",
    "dev:team": "vite --config frontend/team/vite.config.ts",
    "postbuild": "node scripts/copy-dist-entry.js",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:prod": "prisma migrate deploy && node dist/main.js",
    "prestart": "prisma migrate deploy",
    "prisma:seed": "ts-node --transpile-only prisma/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "npm run prisma:seed"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@hookform/resolvers": "^5.4.0",
    "@nestjs/common": "^10.4.8",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.8",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.8",
    "@prisma/client": "^5.22.0",
    "@tiptap/extension-code-block-lowlight": "^3.27.1",
    "@tiptap/extension-highlight": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-mention": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-table-cell": "^3.27.1",
    "@tiptap/extension-table-header": "^3.27.1",
    "@tiptap/extension-table-row": "^3.27.1",
    "@tiptap/extension-task-item": "^3.27.1",
    "@tiptap/extension-task-list": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/suggestion": "^3.27.1",
    "bcrypt": "^5.1.1",
    "chart.js": "^4.5.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "datatables.net": "^2.3.8",
    "datatables.net-dt": "^2.3.8",
    "fast-csv": "^5.0.7",
    "jquery": "^4.0.0",
    "lowlight": "^3.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfmake": "^0.3.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^7.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.3",
    "@types/bcrypt": "^5.0.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^4.5.2",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.19"
  },
  "engines": {
    "node": ">=20"
  }
}
